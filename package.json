{
  "name": "fcmf-cli",
  "version": "0.0.1",
  "description": "Command-line interface for FCMF (Flax Collection Manifest Format)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fcmf": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "watch": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "fcmf",
    "cli",
    "flax",
    "flac"
  ],
  "author": "Valerie Sh. <im@valerie.sh> (https://valerie.sh)",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atvalerie/fcmf-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "music-metadata": "^11.12.3"
  }
}
